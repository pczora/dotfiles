[user]
  email = philipp@czora.dev
  name = Philipp Czora
[init]
  defaultBranch = main
[diff]
  tool = difftastic
[pull]
  rebase = false
[push]
  default = current
[merge]
  tool = nvimdiff
[includeIf "gitdir:~/repos/synaos/"]
  path = ~/.gitconfig_work
[url "ssh://git@github.com/"]
  insteadOf = https://github.com/
[mergetool]
  keepBackup = false
[core]
  pager = "delta"
  autocrlf = input
[delta]
  side-by-side = true
  syntax-theme = base16
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
